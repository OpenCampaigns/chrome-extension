{
    "name": "opencampaigns-extension",
    "version": "1.0.0",
    "description": "OpenCampaigns Ad Replacement Network Extension",
    "type": "module",
    "scripts": {
        "build": "esbuild src/background.ts src/content.ts src/popup.ts --bundle --outdir=dist --format=esm && npm run copy",
        "copy": "cp public/* dist/",
        "test": "vitest run"
    },
    "dependencies": {
        "@opencampaigns/display": "file:../display",
        "@opencampaigns/sdk": "file:../sdk"
    },
    "devDependencies": {
        "@types/chrome": "^0.1.37",
        "esbuild": "^0.20.1",
        "typescript": "^5.3.3",
        "vitest": "^4.0.18"
    }
}
